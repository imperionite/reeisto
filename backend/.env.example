# ---------------- APP ----------------
APP_ENV=development_or_production
APP_PORT=8080
GIN_MODE=release

# ---------------- SECURITY ----------------
JWT_SECRET=supersecretjwtkey

# ---------------- CORS ----------------
CORS_ORIGINS=http://localhost:5173,https://your-frontend-url.com

# ---------------- DATABASE ----------------
# Either use full URL (preferred in Render), manual config or both for flexibility
DB_URL=postgres://dbuser:dbpassword@your-db-host:5432/reetisdb?sslmode=require
# Or, if you prefer manual config:
# DB_HOST=your-db-host
# DB_USER=dbuser
# DB_PASSWORD=dbpassword
# DB_NAME=reetisdb
# DB_PORT=5432
# DB_SSLMODE=require

# ---------------- REDIS ----------------
# Render automatically provides REDIS_URL for managed Redis
REDIS_ADDR=redis://default:password@your-redis-host:6379
REDIS_PASSWORD=  # optional if password included in URL

# ---------------- BOOTSTRAP ----------------
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=supersecure

# ---------------- SEED DATA ----------------
# Only set this in production if you want full dev-like seed
SEED_DATA=true